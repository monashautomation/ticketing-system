generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum TicketStatus {
  open
  pending
  escalated
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum TicketType {
  bug
  suggestion
  improvement
  feature
  question
  other
}

enum MaintenanceStatus {
  scheduled
  in_progress
  resolved
}

enum MaintenanceSource {
  manual
  uptime_kuma
}

/// BetterAuth-managed user table. id/email/emailVerified/name/image/createdAt/updatedAt
/// are BetterAuth core fields; role/discordId are additionalFields configured in auth.ts.
/// The Authentik `sub` lives on Account.accountId (providerId="authentik"), not here.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  role          UserRole  @default(user)
  discordId     String?   @unique
  /// True for a Discord-only placeholder account created before the user has
  /// signed in via Authentik. Cleared (and the row deleted) once claimed --
  /// see DiscordClaim.
  isDiscordPlaceholder Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions        Session[]
  accounts        Account[]
  ticketsCreated  Ticket[]        @relation("TicketCreatedBy")
  ticketsAssigned Ticket[]        @relation("TicketAssignees")
  ticketsWatching Ticket[]        @relation("TicketWatchers")
  messages        TicketMessage[]
  discordClaim    DiscordClaim?
  auditLogs       AuditLog[]
  uploadedAttachments TicketAttachment[]

  @@map("users")
}

/// BetterAuth core table.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

/// BetterAuth core table. accountId = upstream provider's subject (Authentik `sub`).
model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

/// BetterAuth core table (email verification / oauth state, etc).
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Ticket {
  id                String       @id @default(cuid())
  title             String
  description       String
  status            TicketStatus @default(open)
  priority          TicketPriority @default(normal)
  type              TicketType   @default(other)
  createdById       String
  createdBy         User         @relation("TicketCreatedBy", fields: [createdById], references: [id])
  discordChannelId  String?
  slaDueAt          DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  messages     TicketMessage[]
  accessTokens TicketAccessToken[]
  attachments  TicketAttachment[]
  tags         Tag[]               @relation("TicketTags")
  watchers     User[]              @relation("TicketWatchers")
  assignees    User[]              @relation("TicketAssignees")

  @@index([status])
  @@index([createdById])
  @@index([slaDueAt])
  @@map("tickets")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  createdAt DateTime @default(now())

  tickets Ticket[] @relation("TicketTags")

  @@map("tags")
}

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String   @unique
  createdAt    DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_attachments")
}

model TicketMessage {
  id             String   @id @default(cuid())
  ticketId       String
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId       String
  author         User     @relation(fields: [authorId], references: [id])
  body           String
  isInternalNote Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAccessToken {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_access_tokens")
}

/// Tracks a pending Discord-to-Authentik claim for a placeholder user created
/// from a bot-side ticket. One row per placeholder; regenerated/refreshed
/// each time that Discord user opens another ticket before claiming.
model DiscordClaim {
  id                String   @id @default(cuid())
  tokenHash         String   @unique
  placeholderUserId String   @unique
  placeholderUser   User     @relation(fields: [placeholderUserId], references: [id], onDelete: Cascade)
  ticketId          String
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@map("discord_claims")
}

model MaintenanceEvent {
  id            String            @id @default(cuid())
  title         String
  body          String
  status        MaintenanceStatus @default(scheduled)
  startAt       DateTime
  endAt         DateTime?
  source        MaintenanceSource @default(manual)
  kumaMonitorId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([kumaMonitorId])
  @@map("maintenance_events")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@map("audit_log")
}
