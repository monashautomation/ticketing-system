{
  "name": "ticketing-system",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:bot": "pnpm --filter bot dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ticketing/db generate",
    "db:migrate": "pnpm --filter @ticketing/db migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
