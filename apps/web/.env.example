DATABASE_URL="postgresql://ticketing:ticketing@localhost:5432/ticketing?schema=public"

BETTER_AUTH_SECRET="replace-with-32-byte-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Authentik OIDC application (application type: OIDC, client type: confidential)
AUTHENTIK_ISSUER="https://auth.example.com/application/o/ticketing/"
AUTHENTIK_CLIENT_ID="changeme"
AUTHENTIK_CLIENT_SECRET="changeme"

# Comma-separated Authentik group names that should be auto-granted admin
ADMIN_GROUPS="ticketing-admins"

# Shared secret the bot service uses to call internal API routes
INTERNAL_API_SECRET="replace-with-random-secret"

# Shared secret Uptime Kuma's webhook notification must send (custom header)
UPTIME_KUMA_WEBHOOK_SECRET="replace-with-random-secret"

PUBLIC_APP_URL="http://localhost:3000"
