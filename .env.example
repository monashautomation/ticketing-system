# Copy to .env and fill in for `docker compose up`.

BETTER_AUTH_SECRET="replace-with-32-byte-random-secret"

AUTHENTIK_ISSUER="https://auth.example.com/application/o/ticketing/"
AUTHENTIK_CLIENT_ID="changeme"
AUTHENTIK_CLIENT_SECRET="changeme"
ADMIN_GROUPS="ticketing-admins"

INTERNAL_API_SECRET="replace-with-random-secret"
UPTIME_KUMA_WEBHOOK_SECRET="replace-with-random-secret"

# S3/minio-compatible object storage for ticket attachments.
# Local docker compose spins up a minio container with matching defaults.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ticketing-attachments"
S3_ACCESS_KEY_ID="ticketing-minio"
S3_SECRET_ACCESS_KEY="ticketing-minio-secret"
S3_FORCE_PATH_STYLE="true"

DISCORD_DM_API_URL=""
DISCORD_DM_API_KEY="changeme"
